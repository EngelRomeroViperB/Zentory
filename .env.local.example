# ──────────────────────────────────────────────────────────────
# Zentory — Variables de entorno para desarrollo local
# Copia este archivo a .env.local y rellena con tus valores reales.
# NUNCA subas .env.local al repositorio.
# ──────────────────────────────────────────────────────────────

# URL pública del proyecto Supabase (ej: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anon pública — segura para exponer en el cliente (RLS la protege)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role — SOLO para uso en el servidor, NUNCA en el cliente
SUPABASE_SERVICE_ROLE_KEY=

# Identificador único del dispositivo de impresión (para print_queue RLS)
NEXT_PUBLIC_DEVICE_ID=

# ──────────────────────────────────────────────────────────────
# Facturación y Negocio
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_BUSINESS_NAME="Mi Empresa S.A."
NEXT_PUBLIC_BUSINESS_NIT="NIT: 123456789-0"
NEXT_PUBLIC_BUSINESS_ADDRESS="Calle Principal #123, Ciudad"
NEXT_PUBLIC_BUSINESS_PHONE="Tel: (123) 456-7890"
NEXT_PUBLIC_BUSINESS_EMAIL="contacto@miempresa.com"
NEXT_PUBLIC_BUSINESS_MESSAGE="Gracias por su compra!"
NEXT_PUBLIC_DEFAULT_TAX_RATE=19
